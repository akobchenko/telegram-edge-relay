# Example environment file. Export these values into the process environment before startup.
APP_NAME=telegram-edge-relay
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_WEBHOOK_PATH_SECRET=replace-with-long-random-path-secret
BACKEND_BASE_URL=https://backend.internal.example
BACKEND_FORWARD_PATH=/internal/inbound/telegram-update
INTERNAL_SHARED_SECRET=replace-with-long-random-shared-secret
SIGNATURE_TTL_SECONDS=300
TELEGRAM_TIMEOUT_SECONDS=10.0
TELEGRAM_OUTBOUND_MODE=mixed
TELEGRAM_PHOTO_MAX_BYTES=10485760
BACKEND_TIMEOUT_SECONDS=10.0
DEBUG=false
